{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "customer_name": {
      "type": "string"
    },
    "customer_email": {
      "type": "string"
    },
    "quantity": {
      "type": "integer"
    },
    "price": {
      "type": "decimal",
      "default": 0
    },
    "order_date": {
      "type": "date"
    },
    "order_status": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "paid",
        "cancelled"
      ]
    },
    "product": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::product.product",
      "inversedBy": "order"
    }
  }
}
